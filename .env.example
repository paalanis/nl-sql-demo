# ---------------------------------------------------------------------------
# BurgerDemo — Variables de entorno
# ---------------------------------------------------------------------------
# Copiar este archivo a .env y completar los valores reales.
# En Railway se configuran desde el dashboard de variables del servicio.

# ---------------------------------------------------------------------------
# APIs externas (OBLIGATORIAS)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ---------------------------------------------------------------------------
# WhatsApp Cloud API (OBLIGATORIAS)
# ---------------------------------------------------------------------------
# Obtener desde Meta for Developers → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAB...
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Token arbitrario que elegís vos; debe coincidir con el configurado en Meta
WHATSAPP_VERIFY_TOKEN=un_token_secreto

# ---------------------------------------------------------------------------
# Base de datos y queue (OBLIGATORIAS)
# ---------------------------------------------------------------------------
# En Railway, MySQL y Redis son add-ons que inyectan estas vars automáticamente.
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
REDIS_URL=

# ---------------------------------------------------------------------------
# Modelos de Claude (OPCIONALES — tienen default razonable)
# ---------------------------------------------------------------------------
# Clasificador: rápido y barato. Haiku 4.5 por default.
CLASSIFIER_MODEL=claude-haiku-4-5
# Generador de SQL: más potente. Sonnet 4.6.
SQL_MODEL=claude-sonnet-4-6
# Formateador de respuestas WhatsApp: Sonnet por calidad de prosa.
FORMAT_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Comportamiento del pipeline (OPCIONALES)
# ---------------------------------------------------------------------------
# Umbral de confianza del clasificador. Si cae por debajo, el bot pide
# reformulación en vez de intentar responder.
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6

# Max tokens por llamada a la API.
CLASSIFIER_MAX_TOKENS=300
SQL_MAX_TOKENS=500
FORMAT_MAX_TOKENS=400

# Historial conversacional por usuario.
HISTORY_TTL=1800        # segundos (30 min)
MAX_HISTORY_TURNS=5     # últimos N turnos que ve el clasificador
